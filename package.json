{
  "name": "cloudflare-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Cloudflare API (zones, DNS, SSL, tunnels, analytics)",
  "license": "MIT",
  "type": "module",
  "main": "dist/stdio-server.js",
  "bin": {
    "cloudflare-mcp-server": "./dist/stdio-server.js"
  },
  "scripts": {
    "build": "tsc",
    "start:stdio": "node dist/stdio-server.js",
    "dev": "tsx src/stdio-server.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
